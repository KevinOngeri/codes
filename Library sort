#include <stdio.h>

// function prototype 
void librarySort(int arr[], int n);

int main() {
    int arr[10];   // only 10 elements allowed
    int n, i;

    printf("Enter number of elements (max 10): ");
    scanf("%d", &n);

    // validation
    if (n <= 0 || n > 10) {
        printf("Invalid input! You can only enter up to 10 elements.\n");
        return 1;
    }

    printf("Enter the elements:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    librarySort(arr, n);

    printf("Sorted array: ");
    for (i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}

void librarySort(int arr[], int n) {
    int shelf[20];        // double space for gaps
    int size = n * 2;
    int i, j, k, m, index;

    // initialize shelf with empty spaces
    for (i = 0; i < size; i++) {
        shelf[i] = -1;
    }

    shelf[0] = arr[0];

    for (i = 1; i < n; i++) {
        j = 0;

        while (j < size && shelf[j] != -1 && shelf[j] < arr[i]) {
            j++;
        }

        k = j;
        while (k < size && shelf[k] != -1) {
            k++;
        }

        for (m = k; m > j; m--) {
            shelf[m] = shelf[m - 1];
        }

        shelf[j] = arr[i];
    }

    index = 0;
    for (i = 0; i < size; i++) {
        if (shelf[i] != -1) {
            arr[index++] = shelf[i];
        }
    }
}
